#!/bin/bash
#
# Environment configuration for pi-matrix-agent
#
# Copy this file to /etc/pi-matrix-agent/env.conf and fill in the values.
#
# Required variables:
#   CONFIG_FILE        - Path to config.json
#   CONTROL_PUBLIC_URL - Public URL for !control command (Tailscale Serve URL)
#
# Optional variables (have defaults):
#   CONTROL_PORT       - Control server port (default: 9000)
#   CONTROL_HOST       - Control server bind host (default: 127.0.0.1)
#
# Installation:
#   sudo mkdir -p /etc/pi-matrix-agent
#   sudo cp deploy/systemd/env.conf.example /etc/pi-matrix-agent/env.conf
#   sudo nano /etc/pi-matrix-agent/env.conf  # Edit values
#   sudo systemctl restart pi-matrix-agent
#

# =============================================================================
# REQUIRED: Config file path
# =============================================================================

# Path to the config.json file
# This file contains Matrix credentials, LLM configuration, etc.
CONFIG_FILE="/root/homelab/pi-matrix-agent/config.json"

# =============================================================================
# REQUIRED: Control public URL
# =============================================================================

# Public URL for the !control command
# This should be your Tailscale Serve URL (MagicDNS hostname)
# Format: https://<your-node>.<tailnet>.ts.net
#
# Example: https://pi-prototype.example.ts.net
#
# IMPORTANT: This must be set for !control to return the correct public URL
# instead of http://localhost:9000
# Use your Tailscale Serve URL (check with: sudo tailscale serve status)
CONTROL_PUBLIC_URL="https://your-node.tailXXXXX.ts.net"

# =============================================================================
# OPTIONAL: Control server configuration
# =============================================================================

# Control server port (default: 9000)
# Only change if you need a different port
# CONTROL_PORT=9000

# Control server bind host (default: 127.0.0.1)
# Keep as 127.0.0.1 - Tailscale Serve exposes it to the tailnet
# CONTROL_HOST=127.0.0.1

# =============================================================================
# OPTIONAL: Other environment variables
# =============================================================================

# Disable Matrix transport for control-only mode (default: enabled)
# ENABLE_MATRIX="true"

# Node.js environment (default: production)
# NODE_ENV="production"
