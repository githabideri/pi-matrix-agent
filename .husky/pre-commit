#!/bin/sh

STAGED_FILES=$(git diff --cached --name-only)

echo "Running formatting, linting, and type checking..."
npm run check || {
  echo "Checks failed."
  exit 1
}

RUN_LOCAL_SMOKE=0

for file in $STAGED_FILES; do
  case "$file" in
    frontend/operator-ui/*|src/control-server.ts|src/routes/*|views/*|public/*|package.json|package-lock.json)
      RUN_LOCAL_SMOKE=1
      break
      ;;
  esac
done

if [ $RUN_LOCAL_SMOKE -eq 1 ]; then
  echo "Running local smoke test..."
  npm run smoke:local || {
    echo "Local smoke test failed."
    exit 1
  }
fi

for file in $STAGED_FILES; do
  if [ -f "$file" ]; then
    git add "$file" || true  # Ignore errors for ignored files
  fi
done

echo "All pre-commit checks passed."
