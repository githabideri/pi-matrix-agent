{
  "name": "pi-matrix-agent",
  "version": "0.0.1",
  "description": "Minimal Matrix bridge for pi coding agent",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "check": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration"
  },
  "dependencies": {
    "matrix-bot-sdk": "^0.6.2",
    "@mariozechner/pi-coding-agent": "^0.66.1"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "tsx": "^4.7.0",
    "vitest": "^1.3.0",
    "@types/node": "^20.10.0"
  }
}
