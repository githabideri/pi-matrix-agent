{
  "name": "pi-matrix-agent",
  "version": "0.0.1",
  "description": "Minimal Matrix bridge for pi coding agent",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "check": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "verify": "npm test && npm run check && npm run build",
    "smoke:local": "bash ./scripts/smoke-local.sh",
    "smoke:control": "bash ./scripts/smoke-control.sh",
    "smoke:matrix": "bash ./scripts/smoke-matrix.sh",
    "check:single-process": "bash ./scripts/check-single-process.sh"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.66.1",
    "ejs": "^5.0.2",
    "express": "^5.2.1",
    "matrix-bot-sdk": "^0.6.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.3.0"
  }
}
