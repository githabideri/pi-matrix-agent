# Matrix API Configuration (for testing and automation)
# Copy this file to .env.matrix and fill in your values
# DO NOT commit .env.matrix to version control

# Homeserver configuration
MATRIX_HOMESERVER="http://localhost:8008"

# Access token for a user that is in allowedUserIds
# Generate via: curl -X POST "$MATRIX_HOMESERVER/_matrix/client/r0/login" ...
MATRIX_ACCESS_TOKEN=""

# Room ID for the bot room (starts with !)
MATRIX_ROOM_ID=""

# Optional: Username for login (if you want to generate token via login)
MATRIX_USERNAME=""
MATRIX_PASSWORD=""

# Control server configuration
CONTROL_URL="http://127.0.0.1:9000"
CONTROL_PUBLIC_URL="https://your-tailscale-url.ts.net"

# Example: Send a test message
# curl -X POST "$MATRIX_HOMESERVER/_matrix/client/r0/rooms/$MATRIX_ROOM_ID/send/m.room.message" \
#   -H "Authorization: Bearer $MATRIX_ACCESS_TOKEN" \
#   -H "Content-Type: application/json" \
#   -d '{"msgtype":"m.text","body":"test"}'
